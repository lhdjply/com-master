    border: 1px solid #c0c6d0;
    border-radius: 6px;
    margin-top: 12px;
    padding-top: 12px;
    background-color: white;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 8px;
    background-color: white;
    color: #2c3e50;
}
QPushButton {
    background-color: #3498db;
    border: none;
    border-radius: 4px;
    color: white;
    padding: 8px 16px;
    font-weight: bold;
    min-height: 20px;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
    background-color: #21618c;
}
QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}
QComboBox {
    border: 1px solid #c0c6d0;
    border-radius: 4px;
    padding: 6px 12px;
    background-color: white;
    selection-background-color: #3498db;
    selection-color: white;
    min-width: 120px;
    color: black;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #c0c6d0;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid #7f8c8d;
    width: 0;
    height: 0;
}
QTextEdit {
    border: 1px solid #c0c6d0;
    border-radius: 4px;
    padding: 8px;
    background-color: white;
    font-family: 'Consolas', 'Monaco', monospace;
}
QCheckBox {
    spacing: 6px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
}
QCheckBox::indicator:unchecked {
    border: 1px solid #c0c6d0;
    border-radius: 2px;
    background-color: white;
}
QCheckBox::indicator:checked {
    border: 1px solid #3498db;
    border-radius: 2px;
    background-color: #3498db;
}
QLabel {
    color: #2c3e50;
    font-weight: 500;
}
QLineEdit {
    border: 1px solid #c0c6d0;
    border-radius: 4px;
    padding: 6px 8px;
    background-color: white;
}
QLineEdit:focus {
    border-color: #3498db;
}</string>
