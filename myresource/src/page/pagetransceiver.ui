    subcontrol-position: top center;
    padding: 0 8px;
    background-color: white;
    color: #2c3e50;
}
QPushButton {
    background-color: #3498db;
    border: none;
    border-radius: 4px;
    color: white;
    padding: 8px 16px;
    font-weight: bold;
    min-height: 20px;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
